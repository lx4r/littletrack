{
	"name": "time-tracking",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"check": "biome check .",
		"check:staged": "biome check --staged --no-errors-on-unmatched .",
		"check:fix": "biome check --write .",
		"preview": "vite preview",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"test:run": "vitest --run",
		"check-types": "tsc --noEmit --skipLibCheck",
		"precommit": "pnpm run '/^(test:run|check:staged|check-types)$/'",
		"prepare": "husky",
		"deploy": "netlify deploy --prod --dir dist --no-build",
		"generate-test-data": "node --experimental-strip-types src/scripts/generate_test_data.ts"
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/postcss": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"netlify-cli": "^26.0.1",
		"postcss": "^8.5.14",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.5",
		"workbox-window": "^7.4.1"
	}
}
